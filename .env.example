# Configuración de Base de Datos para LxAuth
# Copia este archivo a .env y ajusta los valores

# Conexión a MySQL/MariaDB
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lx_auth
DB_USERNAME=root
DB_PASSWORD=

# Alternativa para MariaDB
# DB_HOST=localhost
# DB_PORT=3307
# DB_DATABASE=lx_auth_mariadb
# DB_USERNAME=mariadb_user
# DB_PASSWORD=mariadb_password

# Configuración de LxAuth
LX_AUTH_JWT_SECRET=your-super-secret-jwt-key-change-in-production
LX_AUTH_LOG_CHANNEL=stack

# Entorno
APP_ENV=local
APP_DEBUG=true
